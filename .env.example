# Copy to .env (never commit .env)
# railway variables import .env   ← push all to Railway in one shot

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/hackathon
DB_USERNAME=postgres
DB_PASSWORD=your_password

# LLM (Groq free tier recommended)
LLM_API_KEY=gsk_your_groq_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
AI_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app

# Spring profile (set to prod on Railway)
SPRING_PROFILES_ACTIVE=prod
